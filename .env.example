# Rename this file to .env for local dev with Wrangler
# .env is gitignored — never commit the real key to Git
#
# For production: set this in Cloudflare Pages dashboard
#   → Settings → Environment variables → Add variable
#
# For local dev: npm install -g wrangler  then  npx wrangler pages dev .

OPENAI_API_KEY=sk-proj-your-key-here
